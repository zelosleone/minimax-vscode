{
  "name": "minimax-vscode",
  "displayName": "MiniMax (coding)",
  "description": "Language model provider for GitHub Copilot in VS Code: use MiniMax text models for programming with a Token Plan API key. Does not add speech, video, or image generation APIs.",
  "version": "1.1.0",
  "publisher": "denizhandaklr",
  "license": "MIT",
  "icon": "icon/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/zelosleone/minimax-vscode"
  },
  "main": "./out/extension.js",
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "ai",
    "minimax",
    "minimax m2.7",
    "token plan",
    "language model",
    "github copilot",
    "chat",
    "coding"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [
    "languageModelThinkingPart"
  ],
  "contributes": {
    "configuration": {
      "title": "MiniMax",
      "properties": {
        "minimax.visibleModels": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "MiniMax-M2.7",
              "MiniMax-M2.7-highspeed",
              "MiniMax-M2.5",
              "MiniMax-M2.5-highspeed",
              "MiniMax-M2.1",
              "MiniMax-M2.1-highspeed",
              "MiniMax-M2"
            ]
          },
          "default": [
            "MiniMax-M2.7",
            "MiniMax-M2.7-highspeed",
            "MiniMax-M2.5",
            "MiniMax-M2.5-highspeed",
            "MiniMax-M2.1",
            "MiniMax-M2.1-highspeed",
            "MiniMax-M2"
          ],
          "uniqueItems": true,
          "scope": "application",
          "markdownDescription": "Programming text models (M2 / M2.1 / M2.5 / M2.7) for Token Plan. Order matches [MiniMax M2.7 for AI coding](https://platform.minimax.io/docs/guides/text-ai-coding-tools). Role-play (M2-her) is not included."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "minimax",
        "displayName": "MiniMax (Token Plan)",
        "configuration": {
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "title": "API key",
              "group": "navigation",
              "description": "MiniMax Token Plan API key from platform.minimax.io (Account / Token Plan)."
            }
          },
          "required": [
            "apiKey"
          ]
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "compile": "tsc -p ./ --noEmit",
    "build": "node esbuild.mjs --production",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc -p ./ --noEmit --watch",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "openai": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.111.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
